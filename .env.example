# Optional LLM API settings. Copy this file to .env and fill only what you use.
# Qwen / DashScope OpenAI-compatible mode:
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Alternative provider-specific keys, if needed later:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
